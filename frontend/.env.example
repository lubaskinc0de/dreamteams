# API Configuration
NUXT_PUBLIC_API_BASE=http://localhost

# Use mock data instead of real API (set to 'false' to use real API)
NUXT_PUBLIC_USE_MOCK=true

# Request timeout in milliseconds (default: 10000)
NUXT_PUBLIC_API_TIMEOUT=10000

# Maximum number of retry attempts for transient failures (default: 3)
NUXT_PUBLIC_API_MAX_RETRIES=3

# Base delay in ms for exponential backoff: delay = baseDelay * 2^attempt + jitter (default: 300)
NUXT_PUBLIC_API_RETRY_BASE_DELAY=300

# Maximum retry delay cap in ms (default: 10000)
NUXT_PUBLIC_API_RETRY_MAX_DELAY=10000
