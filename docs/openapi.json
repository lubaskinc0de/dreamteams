{
    "openapi": "3.1.0",
    "info": { "title": "FastAPI", "version": "0.1.0" },
    "servers": [{ "url": "/api" }],
    "paths": {
        "/internal/alive": {
            "get": {
                "tags": ["Root"],
                "summary": "Alive",
                "description": "HTTP endpoint for liveness probe.",
                "operationId": "alive_internal_alive_get",
                "responses": {
                    "200": {
                        "description": "Successful Response",
                        "content": { "application/json": { "schema": {} } }
                    }
                }
            }
        },
        "/internal/ready": {
            "get": {
                "tags": ["Root"],
                "summary": "Ready",
                "description": "HTTP endpoint for readiness probe.",
                "operationId": "ready_internal_ready_get",
                "responses": {
                    "200": {
                        "description": "Successful Response",
                        "content": { "application/json": { "schema": {} } }
                    }
                }
            }
        },
        "/organizers/": {
            "post": {
                "tags": ["Organizers"],
                "summary": "Register Organizer",
                "description": "HTTP endpoint for registering as ``Organizer``.",
                "operationId": "register_organizer_organizers__post",
                "requestBody": {
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/OrganizerForm"
                            }
                        }
                    },
                    "required": true
                },
                "responses": {
                    "200": {
                        "description": "Successful Response",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/CreatedOrganizer"
                                }
                            }
                        }
                    },
                    "422": {
                        "description": "Validation Error",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/HTTPValidationError"
                                }
                            }
                        }
                    }
                }
            }
        },
        "/users/me": {
            "get": {
                "tags": ["Users"],
                "summary": "View Profile",
                "description": "HTTP endpoint for viewing user profile.",
                "operationId": "view_profile_users_me_get",
                "responses": {
                    "200": {
                        "description": "Successful Response",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/ProfileModel"
                                }
                            }
                        }
                    }
                }
            }
        },
        "/competitions/": {
            "get": {
                "tags": ["Competitions"],
                "summary": "List Competitions",
                "description": "HTTP endpoint for listing competitions.",
                "operationId": "list_competitions_competitions__get",
                "parameters": [
                    {
                        "name": "page",
                        "in": "query",
                        "required": true,
                        "schema": {
                            "type": "integer",
                            "minimum": 1,
                            "title": "Page"
                        }
                    },
                    {
                        "name": "sort_by",
                        "in": "query",
                        "required": true,
                        "schema": {
                            "$ref": "#/components/schemas/CompetitionSortBy"
                        }
                    },
                    {
                        "name": "sort_order",
                        "in": "query",
                        "required": true,
                        "schema": { "$ref": "#/components/schemas/SortOrder" }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Successful Response",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/CompetitionsList"
                                }
                            }
                        }
                    },
                    "422": {
                        "description": "Validation Error",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/HTTPValidationError"
                                }
                            }
                        }
                    }
                }
            },
            "post": {
                "tags": ["Competitions"],
                "summary": "Create Competition",
                "description": "HTTP endpoint for creating a competition.",
                "operationId": "create_competition_competitions__post",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/CompetitionForm"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Successful Response",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/CreatedCompetition"
                                }
                            }
                        }
                    },
                    "422": {
                        "description": "Validation Error",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/HTTPValidationError"
                                }
                            }
                        }
                    }
                }
            }
        },
        "/competitions/{competition_id}": {
            "get": {
                "tags": ["Competitions"],
                "summary": "Read Competition",
                "description": "HTTP endpoint for reading a competition by ID.",
                "operationId": "read_competition_competitions__competition_id__get",
                "parameters": [
                    {
                        "name": "competition_id",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "$ref": "#/components/schemas/CompetitionId"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Successful Response",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/CompetitionModel"
                                }
                            }
                        }
                    },
                    "422": {
                        "description": "Validation Error",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/HTTPValidationError"
                                }
                            }
                        }
                    }
                }
            },
            "put": {
                "tags": ["Competitions"],
                "summary": "Update Competition",
                "description": "HTTP endpoint for updating a competition.",
                "operationId": "update_competition_competitions__competition_id__put",
                "parameters": [
                    {
                        "name": "competition_id",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "$ref": "#/components/schemas/CompetitionId"
                        }
                    }
                ],
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/UpdateCompetitionForm"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Successful Response",
                        "content": { "application/json": { "schema": {} } }
                    },
                    "422": {
                        "description": "Validation Error",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/HTTPValidationError"
                                }
                            }
                        }
                    }
                }
            },
            "delete": {
                "tags": ["Competitions"],
                "summary": "Delete Competition",
                "description": "HTTP endpoint for deleting a competition.",
                "operationId": "delete_competition_competitions__competition_id__delete",
                "parameters": [
                    {
                        "name": "competition_id",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "$ref": "#/components/schemas/CompetitionId"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Successful Response",
                        "content": { "application/json": { "schema": {} } }
                    },
                    "422": {
                        "description": "Validation Error",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/HTTPValidationError"
                                }
                            }
                        }
                    }
                }
            }
        }
    },
    "components": {
        "schemas": {
            "CompetitionForm": {
                "properties": {
                    "title": {
                        "type": "string",
                        "maxLength": 200,
                        "title": "Title"
                    },
                    "description": { "type": "string", "title": "Description" },
                    "schedule": {
                        "$ref": "#/components/schemas/CompetitionSchedule"
                    },
                    "participant_limits": {
                        "$ref": "#/components/schemas/ParticipantLimits"
                    },
                    "domains": {
                        "items": { "$ref": "#/components/schemas/Domain" },
                        "type": "array",
                        "title": "Domains"
                    },
                    "participant_type": {
                        "$ref": "#/components/schemas/ParticipantType"
                    },
                    "venue": {
                        "$ref": "#/components/schemas/CompetitionVenue"
                    },
                    "team_size": {
                        "$ref": "#/components/schemas/TeamSizeRange"
                    },
                    "milestones": {
                        "items": {
                            "$ref": "#/components/schemas/MilestoneForm"
                        },
                        "type": "array",
                        "title": "Milestones"
                    }
                },
                "type": "object",
                "required": [
                    "title",
                    "description",
                    "schedule",
                    "participant_limits",
                    "domains",
                    "participant_type",
                    "venue",
                    "team_size"
                ],
                "title": "CompetitionForm",
                "description": "Form for creating a competition."
            },
            "CompetitionFormat": {
                "type": "string",
                "enum": ["online", "offline", "hybrid"],
                "title": "CompetitionFormat",
                "description": "Format in which a competition is conducted."
            },
            "CompetitionId": { "type": "string", "format": "uuid" },
            "CompetitionModel": {
                "properties": {
                    "id": { "$ref": "#/components/schemas/CompetitionId" },
                    "organizer_id": {
                        "$ref": "#/components/schemas/OrganizerId"
                    },
                    "title": { "type": "string", "title": "Title" },
                    "banner": {
                        "anyOf": [{ "type": "string" }, { "type": "null" }],
                        "title": "Banner"
                    },
                    "description": { "type": "string", "title": "Description" },
                    "schedule": {
                        "$ref": "#/components/schemas/CompetitionSchedule"
                    },
                    "participant_limits": {
                        "$ref": "#/components/schemas/ParticipantLimits"
                    },
                    "domains": {
                        "items": { "$ref": "#/components/schemas/Domain" },
                        "type": "array",
                        "title": "Domains"
                    },
                    "participant_type": {
                        "$ref": "#/components/schemas/ParticipantType"
                    },
                    "venue": {
                        "$ref": "#/components/schemas/CompetitionVenue"
                    },
                    "team_size": {
                        "$ref": "#/components/schemas/TeamSizeRange"
                    },
                    "milestones": {
                        "items": { "$ref": "#/components/schemas/Milestone" },
                        "type": "array",
                        "title": "Milestones"
                    },
                    "is_archived": {
                        "type": "boolean",
                        "title": "Is Archived"
                    },
                    "created_at": {
                        "type": "string",
                        "format": "date-time",
                        "title": "Created At"
                    },
                    "updated_at": {
                        "type": "string",
                        "format": "date-time",
                        "title": "Updated At"
                    }
                },
                "type": "object",
                "required": [
                    "id",
                    "organizer_id",
                    "title",
                    "banner",
                    "description",
                    "schedule",
                    "participant_limits",
                    "domains",
                    "participant_type",
                    "venue",
                    "team_size",
                    "milestones",
                    "is_archived",
                    "created_at",
                    "updated_at"
                ],
                "title": "CompetitionModel",
                "description": "Response model containing competition data."
            },
            "CompetitionSchedule": {
                "properties": {
                    "registration_start": {
                        "type": "string",
                        "format": "date-time",
                        "title": "Registration Start"
                    },
                    "registration_end": {
                        "type": "string",
                        "format": "date-time",
                        "title": "Registration End"
                    },
                    "team_formation_start": {
                        "anyOf": [
                            { "type": "string", "format": "date-time" },
                            { "type": "null" }
                        ],
                        "title": "Team Formation Start"
                    },
                    "team_formation_end": {
                        "anyOf": [
                            { "type": "string", "format": "date-time" },
                            { "type": "null" }
                        ],
                        "title": "Team Formation End"
                    }
                },
                "type": "object",
                "required": ["registration_start", "registration_end"],
                "title": "CompetitionSchedule"
            },
            "CompetitionSortBy": {
                "type": "string",
                "enum": [
                    "created_at",
                    "title",
                    "registration_start",
                    "team_formation_start"
                ],
                "title": "CompetitionSortBy",
                "description": "Fields available for sorting competitions."
            },
            "CompetitionVenue": {
                "properties": {
                    "format": {
                        "$ref": "#/components/schemas/CompetitionFormat"
                    },
                    "location": {
                        "anyOf": [{ "type": "string" }, { "type": "null" }],
                        "title": "Location"
                    }
                },
                "type": "object",
                "required": ["format", "location"],
                "title": "CompetitionVenue"
            },
            "CompetitionsList": {
                "properties": {
                    "items": {
                        "items": {
                            "$ref": "#/components/schemas/CompetitionModel"
                        },
                        "type": "array",
                        "title": "Items"
                    },
                    "total": { "type": "integer", "title": "Total" },
                    "page": { "type": "integer", "title": "Page" }
                },
                "type": "object",
                "required": ["items", "total", "page"],
                "title": "CompetitionsList",
                "description": "Response model containing paginated list of competitions."
            },
            "CreatedCompetition": {
                "properties": {
                    "competition_id": {
                        "$ref": "#/components/schemas/CompetitionId"
                    }
                },
                "type": "object",
                "required": ["competition_id"],
                "title": "CreatedCompetition",
                "description": "Response model containing the created competition identifier."
            },
            "CreatedOrganizer": {
                "properties": {
                    "organizer_id": {
                        "$ref": "#/components/schemas/OrganizerId"
                    },
                    "user_id": { "$ref": "#/components/schemas/UserId" }
                },
                "type": "object",
                "required": ["organizer_id", "user_id"],
                "title": "CreatedOrganizer",
                "description": "Response model containing the info about newly created ``Organizer`` and ``User``."
            },
            "Domain": {
                "type": "string",
                "enum": ["frontend", "mobile", "backend", "ai", "devops"],
                "title": "Domain",
                "description": "IT domain area."
            },
            "HTTPValidationError": {
                "properties": {
                    "detail": {
                        "items": {
                            "$ref": "#/components/schemas/ValidationError"
                        },
                        "type": "array",
                        "title": "Detail"
                    }
                },
                "type": "object",
                "title": "HTTPValidationError"
            },
            "Logo": { "type": "string" },
            "Milestone": {
                "properties": {
                    "timestamp": {
                        "type": "string",
                        "format": "date-time",
                        "title": "Timestamp"
                    },
                    "title": { "type": "string", "title": "Title" }
                },
                "type": "object",
                "required": ["timestamp", "title"],
                "title": "Milestone"
            },
            "MilestoneForm": {
                "properties": {
                    "title": {
                        "type": "string",
                        "maxLength": 50,
                        "title": "Title"
                    },
                    "timestamp": {
                        "type": "string",
                        "format": "date-time",
                        "title": "Timestamp"
                    }
                },
                "type": "object",
                "required": ["title", "timestamp"],
                "title": "MilestoneForm",
                "description": "Form for creating a milestone."
            },
            "OrganizerForm": {
                "properties": {
                    "organizer_name": {
                        "type": "string",
                        "maxLength": 70,
                        "title": "Organizer Name"
                    },
                    "phone_number": {
                        "type": "string",
                        "format": "phone",
                        "title": "Phone Number"
                    }
                },
                "type": "object",
                "required": ["organizer_name", "phone_number"],
                "title": "OrganizerForm",
                "description": "Organizer form without email (email provided from external id service for web)."
            },
            "OrganizerId": { "type": "string", "format": "uuid" },
            "OrganizerModel": {
                "properties": {
                    "id": { "$ref": "#/components/schemas/OrganizerId" },
                    "user_id": { "$ref": "#/components/schemas/UserId" },
                    "organizer_name": {
                        "type": "string",
                        "title": "Organizer Name"
                    },
                    "phone_number": {
                        "type": "string",
                        "title": "Phone Number"
                    },
                    "contact_email": {
                        "type": "string",
                        "title": "Contact Email"
                    },
                    "logo": {
                        "anyOf": [
                            { "$ref": "#/components/schemas/Logo" },
                            { "type": "null" }
                        ]
                    }
                },
                "type": "object",
                "required": [
                    "id",
                    "user_id",
                    "organizer_name",
                    "phone_number",
                    "contact_email",
                    "logo"
                ],
                "title": "OrganizerModel",
                "description": "Response model containing the info about ``Organizer``."
            },
            "ParticipantLimits": {
                "properties": {
                    "max": { "type": "integer", "title": "Max" },
                    "min": { "type": "integer", "title": "Min" }
                },
                "type": "object",
                "required": ["max", "min"],
                "title": "ParticipantLimits"
            },
            "ParticipantType": {
                "type": "string",
                "enum": ["schoolchild", "student", "any"],
                "title": "ParticipantType",
                "description": "Target audience category for a competition."
            },
            "ProfileModel": {
                "properties": {
                    "user_id": { "$ref": "#/components/schemas/UserId" },
                    "organizer": {
                        "anyOf": [
                            { "$ref": "#/components/schemas/OrganizerModel" },
                            { "type": "null" }
                        ]
                    }
                },
                "type": "object",
                "required": ["user_id", "organizer"],
                "title": "ProfileModel",
                "description": "Response model containing the info about user profile."
            },
            "SortOrder": {
                "type": "string",
                "enum": ["asc", "desc"],
                "title": "SortOrder",
                "description": "Sort order for listing operations."
            },
            "TeamSizeRange": {
                "properties": {
                    "max": { "type": "integer", "title": "Max" },
                    "min": { "type": "integer", "title": "Min" }
                },
                "type": "object",
                "required": ["max", "min"],
                "title": "TeamSizeRange"
            },
            "UpdateCompetitionForm": {
                "properties": {
                    "title": {
                        "type": "string",
                        "maxLength": 200,
                        "title": "Title"
                    },
                    "description": { "type": "string", "title": "Description" },
                    "schedule": {
                        "$ref": "#/components/schemas/CompetitionSchedule"
                    },
                    "participant_limits": {
                        "$ref": "#/components/schemas/ParticipantLimits"
                    },
                    "domains": {
                        "items": { "$ref": "#/components/schemas/Domain" },
                        "type": "array",
                        "title": "Domains"
                    },
                    "participant_type": {
                        "$ref": "#/components/schemas/ParticipantType"
                    },
                    "venue": {
                        "$ref": "#/components/schemas/CompetitionVenue"
                    },
                    "team_size": {
                        "$ref": "#/components/schemas/TeamSizeRange"
                    },
                    "milestones": {
                        "items": {
                            "$ref": "#/components/schemas/MilestoneForm"
                        },
                        "type": "array",
                        "title": "Milestones"
                    },
                    "is_archived": { "type": "boolean", "title": "Is Archived" }
                },
                "type": "object",
                "required": [
                    "title",
                    "description",
                    "schedule",
                    "participant_limits",
                    "domains",
                    "participant_type",
                    "venue",
                    "team_size",
                    "milestones",
                    "is_archived"
                ],
                "title": "UpdateCompetitionForm",
                "description": "Form for updating a competition."
            },
            "UserId": { "type": "string", "format": "uuid" },
            "ValidationError": {
                "properties": {
                    "loc": {
                        "items": {
                            "anyOf": [
                                { "type": "string" },
                                { "type": "integer" }
                            ]
                        },
                        "type": "array",
                        "title": "Location"
                    },
                    "msg": { "type": "string", "title": "Message" },
                    "type": { "type": "string", "title": "Error Type" }
                },
                "type": "object",
                "required": ["loc", "msg", "type"],
                "title": "ValidationError"
            }
        }
    }
}
